{
	"name": "react-githubpages3",
	"version": "0.0.7",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev",
		"start": "react-router-serve ./build/server/index.js",
		"preview": "pnpx http-server -c 1 -p 4173 ./build/client",
		"preview2": "pnpx http-server -c 1 -p 4173 ./build",
		"typecheck": "react-router typegen && tsc",
		"preinstall": "pnpm audit",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix"
	},
	"dependencies": {
		"@react-router/node": "^7.14.0",
		"@react-router/serve": "^7.14.0",
		"isbot": "^5.1.37",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.14.0"
	},
	"devDependencies": {
		"@react-router/dev": "^7.14.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"react-router-devtools": "^6.2.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.5"
	}
}
