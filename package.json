{
	"name": "react-githubpages3",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev",
		"start": "react-router-serve ./build/server/index.js",
		"preview": "pnpx http-server -c 1 -p 4173 ./build/client",
		"preview2": "pnpx http-server -c 1 -p 4173 ./build",
		"typecheck": "react-router typegen && tsc",
		"format": "biome format --write . && dprint fmt  && textlint --fix \"**/*.md\""
	},
	"dependencies": {
		"@react-router/node": "^7.13.1",
		"@react-router/serve": "^7.13.1",
		"isbot": "^5.1.35",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1"
	},
	"devDependencies": {
		"@react-router/dev": "^7.13.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"react-router-devtools": "^6.2.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"version": "0.0.7"
}
